        if st.button("🚪 Logout", use_container_width=True):
            logout()

    st.markdown('<p class="main-title">🛠️ Admin Dashboard</p>', unsafe_allow_html=True)
    st.markdown("---")

    # ── Initialise DB connection ──────────────
    # db = Database()          # ← uncomment when your Database class is ready

    # ─────────────────────────────────────────
    # VIEW STUDENTS
    # ─────────────────────────────────────────
    if section == "📊 View Students":
        st.subheader("All Students")

        # students = db.fetch_all_students()
        # Replace the two lines below with real DB data when ready:
        students = st.session_state.get("mock_students", [])

        if students:
            df = pd.DataFrame(students, columns=["ID", "Name", "Age", "Grade"])
            st.dataframe(df, use_container_width=True, hide_index=True)
        else:
            st.info("No students found in the database.")

    # ─────────────────────────────────────────
    # ADD STUDENT
    # ─────────────────────────────────────────
    elif section == "➕ Add Student":
        st.subheader("Add a New Student")
        with st.form("add_student_form"):
            name  = st.text_input("Student Name")
            age   = st.number_input("Age", min_value=1, max_value=100, step=1)
            grade = st.text_input("Grade (e.g. A, B+, 90%)")
            add   = st.form_submit_button("Add Student", use_container_width=True)

        if add:
            if not name or not grade:
                st.error("❌ Name and Grade are required.")
            else:
                # student = Student(name=name, age=int(age), grade=grade)
                # db.insert_student(student)
                # Mock persistence for demo purposes:
                mock = st.session_state.get("mock_students", [])
                new_id = (mock[-1][0] + 1) if mock else 1
                mock.append([new_id, name, int(age), grade])
                st.session_state["mock_students"] = mock
                st.success(f"✅ Student **{name}** added successfully!")

    # ─────────────────────────────────────────
    # UPDATE STUDENT
    # ─────────────────────────────────────────
    elif section == "✏️ Update Student":
        st.subheader("Update an Existing Student")
        student_id = st.number_input("Enter Student ID to update",
                                     min_value=1, step=1)
        with st.form("update_student_form"):
            new_name  = st.text_input("New Name  (leave blank to keep current)")
            new_age   = st.number_input("New Age   (0 = keep current)",
                                        min_value=0, max_value=120, step=1)
            new_grade = st.text_input("New Grade (leave blank to keep current)")
            update    = st.form_submit_button("Update Student", use_container_width=True)

        if update:
            mock = st.session_state.get("mock_students", [])
            found = False
            for row in mock:
                if row[0] == student_id:
                    if new_name:  row[1] = new_name
                    if new_age:   row[2] = int(new_age)
                    if new_grade: row[3] = new_grade
                    found = True
                    break
            st.session_state["mock_students"] = mock

            if found:
                st.success(f"✅ Student ID **{student_id}** updated successfully.")
            else:
                st.error(f"❌ No student found with ID {student_id}.")

    # ─────────────────────────────────────────
    # DELETE STUDENT
    # ─────────────────────────────────────────
    elif section == "🗑️ Delete Student":
        st.subheader("Delete a Student")
        student_id = st.number_input("Enter Student ID to delete",
                                     min_value=1, step=1)

        if st.button("Delete Student", type="primary"):
            mock = st.session_state.get("mock_students", [])
            before = len(mock)
            mock = [r for r in mock if r[0] != student_id]
            st.session_state["mock_students"] = mock

            if len(mock) < before:
                st.success(f"✅ Student ID **{student_id}** deleted successfully.")
            else:
                st.error(f"❌ No student found with ID {student_id}.")

    # ─────────────────────────────────────────
    # BULK UPLOAD (CSV)
    # ─────────────────────────────────────────
    elif section == "📂 Bulk Upload (CSV)":
        st.subheader("Bulk Upload Students via CSV")
        st.markdown(
            "Upload a CSV file with columns: **name, age, grade**  \n"
            "An `id` column is optional — the database auto-generates IDs."
        )
        uploaded = st.file_uploader("Choose a CSV file", type=["csv"])
        if uploaded:
            try:
                df = pd.read_csv(uploaded)
                required_cols = {"name", "age", "grade"}
                if not required_cols.issubset(set(df.columns.str.lower())):
                    st.error("❌ CSV must contain columns: name, age, grade")
                else:
                    df.columns = df.columns.str.lower()
                    st.dataframe(df, use_container_width=True)

                    if st.button("Upload to Database"):
                        mock = st.session_state.get("mock_students", [])
                        next_id = (mock[-1][0] + 1) if mock else 1
                        for _, row in df.iterrows():
                            mock.append([next_id, row["name"],
                                         int(row["age"]), row["grade"]])
                            next_id += 1
                        st.session_state["mock_students"] = mock
                        st.success(f"✅ {len(df)} student(s) uploaded successfully!")
            except Exception as e:
                st.error(f"❌ Failed to process file: {e}")


