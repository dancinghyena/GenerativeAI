            send = st.form_submit_button("Send", use_container_width=True)

    if send and user_input.strip():
        # Save the user's message
        st.session_state.chat_history.append(
            {"role": "user", "text": user_input.strip()}
        )

        # ── Get bot response ──────────────────
        # Replace this stub with: response = chatbot.respond(user_input)
        response = _mock_chatbot_response(user_input.strip())

        st.session_state.chat_history.append(
            {"role": "bot", "text": response}
        )
        st.rerun()


def _mock_chatbot_response(query: str) -> str:
    """
    Stub response generator.
    Replace this entire function body with:
        return chatbot.respond(query)
    once your Chatbot class is connected.
    """
    q = query.lower()
    mock = st.session_state.get("mock_students", [])

    if "how many" in q or "count" in q or "total" in q:
        return f"There are currently **{len(mock)}** student(s) in the database."

    if "average age" in q or "avg age" in q:
        if mock:
            avg = sum(r[2] for r in mock) / len(mock)
            return f"The average age of all students is **{avg:.1f}** years."
        return "No student records found to calculate an average."

    if "youngest" in q:
        if mock:
            s = min(mock, key=lambda r: r[2])
            return f"The youngest student is **{s[1]}** (Age {s[2]}, Grade {s[3]})."
        return "No student records found."

    if "oldest" in q:
        if mock:
            s = max(mock, key=lambda r: r[2])
            return f"The oldest student is **{s[1]}** (Age {s[2]}, Grade {s[3]})."
        return "No student records found."

    if "grade" in q:
        # Extract a grade keyword from the query (e.g. "grade A")
        words = query.upper().split()
        target = None
        for i, w in enumerate(words):
            if w == "GRADE" and i + 1 < len(words):
                target = words[i + 1].strip(".,!?")
                break
        if target:
            results = [r for r in mock if r[3].upper() == target]
            if results:
                names = ", ".join(r[1] for r in results)
                return f"Students in Grade **{target}**: {names}."
            return f"No students found in Grade **{target}**."
        return ("Please specify the grade you're looking for, "
                "e.g. 'Show me students in grade A'.")

    if "list" in q or "show all" in q or "all students" in q:
        if mock:
            lines = "\n".join(
                f"• ID {r[0]}: {r[1]}, Age {r[2]}, Grade {r[3]}" for r in mock
            )
            return f"Here are all students:\n\n{lines}"
        return "The student database is currently empty."

    # Default fallback
    return ("I'm not sure how to answer that. Try asking about student counts, "
            "average age, youngest/oldest students, or students by grade.")


